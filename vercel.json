{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/works",
      "destination": "/index.html"
    },
    {
      "source": "/styles",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "redirects": [
    { "source": "/page", "destination": "/blog", "permanent": true }
  ]
}
